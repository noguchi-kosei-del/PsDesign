{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PsDesign",
  "version": "1.9.0",
  "identifier": "com.psdesign.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PsDesign",
        "width": 1360,
        "height": 820,
        "minWidth": 1300,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/pdfium/pdfium.dll",
      "scripts/install-ai-models.ps1"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/noguchi-kosei-del/PsDesign/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ0NzJDOUE1QTNBNENDQUQKUldTdHpLU2pwY2x5UkcwL3ZzeURiWTNrOW40MjFwOHpwUlR4cnpOSFp1OXROS0ZCYktoY3plSUgK"
    }
  }
}
